@{
    Layout = null; ViewData["Title"] = "Courses";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Courses – 3TagaPayu AMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>
    <!-- Loading screen — change img src to swap logo -->
    <!-- Dots: codepen.io/nzbin/pen/GGrXbp (MIT) | Pulse: uiverse.io loading styles -->
    <div id="pageLoader">
        <img src="~/assets/dbtc.png" alt="Loading" class="loader-logo">
        <div class="loader-dots"><span></span><span></span><span></span></div>
        <p class="loader-text">Loading...</p>
    </div>

    @await Html.PartialAsync("_AdminSidebar", "Courses")
    <div class="main">
        @await Html.PartialAsync("_Topbar", new ViewDataDictionary(ViewData) { { "User", "Administrator" }, { "Role", "Admin" } })
        <div class="page-content">
            <div class="panel">
                <div class="panel-header">
                    <i class="fas fa-book panel-icon"></i>
                    <img src="~/assets/dbtc.png" alt="">
                    <h2>Manage Courses</h2>
                </div>

                <div class="tab-group">
                    <button class="tab-btn active">Manage Courses</button>
                    <button class="tab-btn">Enroll Students</button>
                </div>

                <p style="font-size:0.78rem;font-weight:600;color:var(--accent);margin-bottom:12px;letter-spacing:0.5px;">+ ADD NEW COURSE</p>

                <div class="form-row" style="margin-bottom:24px;">
                    <div class="form-field">
                        <label>Course Code</label>
                        <input type="text" placeholder="e.g. IT 213A" style="min-width:130px;">
                    </div>
                    <div class="form-field" style="flex:1">
                        <label>Course Name</label>
                        <input type="text" placeholder="e.g. Systems Integration">
                    </div>
                    <div class="form-field">
                        <label>Units</label>
                        <select style="min-width:80px;"><option>3</option><option>2</option><option>1</option></select>
                    </div>
                    <div class="form-field">
                        <label>Section</label>
                        <select style="min-width:100px;"><option>IT-3A</option><option>IT-3B</option><option>IT-4A</option></select>
                    </div>
                    <div class="form-field" style="flex:1">
                        <label>Assigned Teacher</label>
                        <select><option>Carl Joshua Santos</option><option>Shaira Ejares</option><option>Clyde Parba</option></select>
                    </div>
                    <div class="form-field" style="justify-content:flex-end;">
                        <label>&nbsp;</label>
                        <button class="btn btn-primary">Add</button>
                    </div>
                </div>

                <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.7px;color:var(--muted);margin-bottom:10px;">Course List</p>

                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Course Name</th>
                            <th>Units</th>
                            <th>Section</th>
                            <th>Teacher</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td><span class="course-tag">IT 212A</span></td><td>Network Management 2</td><td>3</td><td>IT-3A</td><td>Carl Joshua Santos</td><td><button class="btn btn-ghost" style="padding:5px 12px;font-size:0.78rem;">Edit</button></td></tr>
                        <tr><td><span class="course-tag">IT 213A</span></td><td>Systems Integration</td><td>3</td><td>IT-3B</td><td>Shaira Ejares</td><td><button class="btn btn-ghost" style="padding:5px 12px;font-size:0.78rem;">Edit</button></td></tr>
                        <tr><td><span class="course-tag">IT 214A</span></td><td>Capstone Project 1</td><td>3</td><td>IT-4A</td><td>Carl Joshua Santos</td><td><button class="btn btn-ghost" style="padding:5px 12px;font-size:0.78rem;">Edit</button></td></tr>
                        <tr><td><span class="course-tag">IT 215A</span></td><td>Web Systems Dev</td><td>3</td><td>IT-4A</td><td>Clyde Parba</td><td><button class="btn btn-ghost" style="padding:5px 12px;font-size:0.78rem;">Edit</button></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script src="~/js/dashboard.js"></script>
</body>
</html>