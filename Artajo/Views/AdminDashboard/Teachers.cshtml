@{
    Layout = null; ViewData["Title"] = "Teachers";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Teachers – 3TagaPayu AMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>
    <div id="pageLoader">
        <img src="~/assets/dbtc.png" alt="Loading" class="loader-logo">
        <div class="loader-dots"><span></span><span></span><span></span></div>
        <p class="loader-text">Loading...</p>
    </div>

    @await Html.PartialAsync("_AdminSidebar", "Teachers")
    <div class="main">
        @await Html.PartialAsync("_Topbar", new ViewDataDictionary(ViewData) { { "User", "Administrator" }, { "Role", "Admin" } })
        <div class="page-content">
            <div class="panel">
                <div class="panel-header">
                    <i class="fas fa-chalkboard-teacher panel-icon"></i>
                    <img src="~/assets/Teacher_logo.png" alt="">
                    <h2>Manage Teachers</h2>
                </div>

                <p style="font-size:0.78rem;font-weight:600;color:var(--accent);margin-bottom:12px;letter-spacing:0.5px;">+ ADD NEW TEACHER</p>

                <div class="form-row" style="margin-bottom:20px;">
                    <div class="form-field">
                        <label>Teacher ID</label>
                        <input type="text" value="TCH-008" style="min-width:110px;">
                    </div>
                    <div class="form-field">
                        <label>First Name</label>
                        <input type="text" placeholder="First name" style="min-width:140px;">
                    </div>
                    <div class="form-field" style="flex:1">
                        <label>Last Name</label>
                        <input type="text" placeholder="Last name">
                    </div>
                    <div class="form-field" style="flex:1">
                        <label>Email</label>
                        <input type="email" placeholder="email@dbtc.edu.ph">
                    </div>
                    <div class="form-field" style="justify-content:flex-end;">
                        <label>&nbsp;</label>
                        <button class="btn btn-primary" onclick="showToast('Teacher added successfully!','success')">Add</button>
                    </div>
                </div>

                <div class="search-bar" style="margin-bottom:16px;">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search teachers...">
                </div>

                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Teacher ID</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Courses</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="num-col">1</td>
                            <td class="mono">TCH-001</td>
                            <td><strong>Santos, Carl Joshua</strong></td>
                            <td style="color:var(--muted)">carl@dbtc.edu.ph</td>
                            <td>3</td>
                            <td><span class="badge badge-active">Active</span></td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;" onclick="openEditTeacher('TCH-001','Santos, Carl Joshua','carl@dbtc.edu.ph')">Edit</button>
                                    <button class="btn btn-warning" style="padding:5px 10px;font-size:0.78rem;" onclick="confirmDisableTeacher('Santos, Carl Joshua')">Disable</button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">2</td>
                            <td class="mono">TCH-002</td>
                            <td><strong>Parba, Clyde</strong></td>
                            <td style="color:var(--muted)">clyde@dbtc.edu.ph</td>
                            <td>2</td>
                            <td><span class="badge badge-active">Active</span></td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;" onclick="openEditTeacher('TCH-002','Parba, Clyde','clyde@dbtc.edu.ph')">Edit</button>
                                    <button class="btn btn-warning" style="padding:5px 10px;font-size:0.78rem;" onclick="confirmDisableTeacher('Parba, Clyde')">Disable</button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">3</td>
                            <td class="mono">TCH-003</td>
                            <td><strong>Oraiz, Cassandra</strong></td>
                            <td style="color:var(--muted)">cassandra@dbtc.edu.ph</td>
                            <td>2</td>
                            <td><span class="badge badge-active">Active</span></td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;" onclick="openEditTeacher('TCH-003','Oraiz, Cassandra','cassandra@dbtc.edu.ph')">Edit</button>
                                    <button class="btn btn-warning" style="padding:5px 10px;font-size:0.78rem;" onclick="confirmDisableTeacher('Oraiz, Cassandra')">Disable</button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">4</td>
                            <td class="mono">TCH-004</td>
                            <td><strong>Bangoy, Leila M.</strong></td>
                            <td style="color:var(--muted)">leila@dbtc.edu.ph</td>
                            <td>1</td>
                            <td><span class="badge badge-active">Active</span></td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;" onclick="openEditTeacher('TCH-004','Bangoy, Leila M.','leila@dbtc.edu.ph')">Edit</button>
                                    <button class="btn btn-warning" style="padding:5px 10px;font-size:0.78rem;" onclick="confirmDisableTeacher('Bangoy, Leila M.')">Disable</button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">5</td>
                            <td class="mono">TCH-005</td>
                            <td><strong>Ejares, Shaira</strong></td>
                            <td style="color:var(--muted)">shaira@dbtc.edu.ph</td>
                            <td>2</td>
                            <td><span class="badge badge-active">Active</span></td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;" onclick="openEditTeacher('TCH-005','Ejares, Shaira','shaira@dbtc.edu.ph')">Edit</button>
                                    <button class="btn btn-warning" style="padding:5px 10px;font-size:0.78rem;" onclick="confirmDisableTeacher('Ejares, Shaira')">Disable</button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">6</td>
                            <td class="mono">TCH-006</td>
                            <td><strong>Pal, Carol</strong></td>
                            <td style="color:var(--muted)">carol@dbtc.edu.ph</td>
                            <td>1</td>
                            <td><span class="badge badge-active">Active</span></td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;" onclick="openEditTeacher('TCH-006','Pal, Carol','carol@dbtc.edu.ph')">Edit</button>
                                    <button class="btn btn-warning" style="padding:5px 10px;font-size:0.78rem;" onclick="confirmDisableTeacher('Pal, Carol')">Disable</button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">7</td>
                            <td class="mono">TCH-007</td>
                            <td><strong>Domen, Janine</strong></td>
                            <td style="color:var(--muted)">janine@dbtc.edu.ph</td>
                            <td>1</td>
                            <td><span class="badge badge-disabled">Disabled</span></td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;" onclick="openEditTeacher('TCH-007','Domen, Janine','janine@dbtc.edu.ph')">Edit</button>
                                    <button class="btn btn-success" style="padding:5px 10px;font-size:0.78rem;" onclick="confirmDisableTeacher('Domen, Janine')">Enable</button>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Edit Teacher Modal -->
    <div class="modal-backdrop" id="editTeacherModal">
        <div class="modal">
            <div class="modal-header">
                <h3><i class="fas fa-user-edit"></i> Edit Teacher</h3>
                <button class="modal-close" onclick="closeModal('editTeacherModal')"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="modal-field">
                    <label>Teacher ID</label>
                    <input type="text" id="editTeacherId" readonly>
                </div>
                <div class="modal-field">
                    <label>Full Name</label>
                    <input type="text" id="editTeacherName">
                </div>
                <div class="modal-field">
                    <label>Email</label>
                    <input type="email" id="editTeacherEmail">
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" onclick="closeModal('editTeacherModal')">Cancel</button>
                <button class="btn btn-primary" onclick="saveEditTeacher()">Save Changes</button>
            </div>
        </div>
    </div>

    <!-- Disable/Enable Teacher Modal -->
    <div class="modal-backdrop" id="disableTeacherModal">
        <div class="modal">
            <div class="modal-header">
                <h3><i class="fas fa-user-slash warning"></i> Confirm Action</h3>
                <button class="modal-close" onclick="closeModal('disableTeacherModal')"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to change the status of <strong id="disableTeacherName"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" onclick="closeModal('disableTeacherModal')">Cancel</button>
                <button class="btn btn-warning" onclick="confirmAction()">Yes, Confirm</button>
            </div>
        </div>
    </div>

    <script src="~/js/dashboard.js"></script>
</body>
</html>