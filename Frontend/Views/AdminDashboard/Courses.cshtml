@{
    Layout = null; ViewData["Title"] = "Courses";
    var courses = ViewBag.Courses as List<Frontend.Controllers.CourseDto> ?? new();
    var teachers = ViewBag.Teachers as List<Frontend.Controllers.TeacherDto> ?? new();
    var username = ViewBag.Username?.ToString() ?? "Administrator";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Courses – 3TagaPayu AMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.10.5/sweetalert2.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.12.0/toastify.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>
    <div id="pageLoader">
        <img src="~/assets/dbtc.png" alt="Loading" class="loader-logo">
        <div class="loader-dots"><span></span><span></span><span></span></div>
        <p class="loader-text">Loading...</p>
    </div>

    @await Html.PartialAsync("_AdminSidebar", "Courses")
    <div class="main">
        @{
            ViewData["User"] = username; ViewData["Role"] = "Admin";
        }
        @await Html.PartialAsync("_Topbar")
        <div class="page-content">

            @if (TempData["Success"] != null)
            {
                <div style="background:#22c55e20;border:1px solid #22c55e;border-radius:8px;padding:12px 16px;margin-bottom:16px;color:#22c55e;font-size:0.85rem;">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div style="background:#ef444420;border:1px solid #ef4444;border-radius:8px;padding:12px 16px;margin-bottom:16px;color:#ef4444;font-size:0.85rem;">
                    <i class="fas fa-times-circle"></i> @TempData["Error"]
                </div>
            }

            <div class="panel">
                <div class="panel-header">
                    <i class="fas fa-book panel-icon"></i>
                    <h2>Manage Courses</h2>
                </div>

                <p style="font-size:0.78rem;font-weight:600;color:var(--accent);margin-bottom:12px;letter-spacing:0.5px;">+ ADD NEW COURSE</p>

                <form method="post" asp-action="AddCourse" asp-controller="AdminDashboard">
                    @Html.AntiForgeryToken()
                    <div class="form-row" style="margin-bottom:20px;flex-wrap:wrap;gap:10px;">
                        <div class="form-field">
                            <label>Course Code</label>
                            <input type="text" name="courseCode" placeholder="CC101" style="min-width:110px;">
                        </div>
                        <div class="form-field" style="flex:1">
                            <label>Course Name</label>
                            <input type="text" name="courseName" placeholder="Course name">
                        </div>
                        <div class="form-field">
                            <label>Units</label>
                            <input type="number" name="units" value="3" min="1" max="6" style="min-width:70px;">
                        </div>
                        <div class="form-field">
                            <label>Section</label>
                            <select name="section" style="min-width:100px;">
                                <option>IT-3A</option>
                                <option>IT-3B</option>
                                <option>IT-4A</option>
                            </select>
                        </div>
                        <div class="form-field" style="flex:1">
                            <label>Schedule</label>
                            <input type="text" name="schedule" placeholder="Mon/Wed 9:00–10:30">
                        </div>
                        <div class="form-field" style="flex:1">
                            <label>Teacher</label>
                            <select name="teacherId" style="min-width:160px;">
                                <option value="">-- Select Teacher --</option>
                                @foreach (var t in teachers)
                                {
                                    <option value="@t.Id">@t.LastName, @t.FirstName</option>
                                }
                            </select>
                        </div>
                        <div class="form-field" style="justify-content:flex-end;">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary">Add</button>
                        </div>
                    </div>
                </form>

                <table class="data-table" id="coursesTable" data-dt>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Code</th>
                            <th>Course Name</th>
                            <th>Units</th>
                            <th>Section</th>
                            <th>Schedule</th>
                            <th>Teacher</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int cn = 1;
                        }
                        @foreach (var c in courses)
                        {
                            <tr>
                                <td>@cn</td>
                                <td class="mono">@c.CourseCode</td>
                                <td><strong>@c.CourseName</strong></td>
                                <td>@c.Units</td>
                                <td><span class="section-tag">@c.Section</span></td>
                                <td style="color:var(--muted);font-size:0.82rem;">@c.Schedule</td>
                                <td>@c.TeacherName</td>
                                <td>
                                    <div style="display:flex;gap:6px;">
                                        <button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;"
                                                data-id="@c.Id" data-code="@c.CourseCode" data-name="@c.CourseName"
                                                data-units="@c.Units" data-section="@c.Section"
                                                data-schedule="@c.Schedule" data-teacherid="@c.TeacherId"
                                                onclick="openEditCourseFromBtn(this)">
                                            Edit
                                        </button>
                                        <button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;"
                                                data-id="@c.Id" data-name="@c.CourseName"
                                                onclick="confirmDeleteCourseFromBtn(this)">
                                            Del
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            cn++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Edit Course Modal -->
    <div class="modal-backdrop" id="editCourseModal">
        <div class="modal">
            <div class="modal-header">
                <h3><i class="fas fa-book"></i> Edit Course</h3>
                <button class="modal-close" onclick="closeModal('editCourseModal')"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="modal-field"><label>Course Code</label><input type="text" id="ecCode"></div>
                <div class="modal-field"><label>Course Name</label><input type="text" id="ecName"></div>
                <div class="modal-field"><label>Units</label><input type="number" id="ecUnits" min="1" max="6"></div>
                <div class="modal-field">
                    <label>Section</label>
                    <select id="ecSection"><option>IT-3A</option><option>IT-3B</option><option>IT-4A</option></select>
                </div>
                <div class="modal-field"><label>Schedule</label><input type="text" id="ecSchedule"></div>
                <div class="modal-field">
                    <label>Teacher</label>
                    <select id="ecTeacherId">
                        @foreach (var t in teachers)
                        {
                            <option value="@t.Id">@t.LastName, @t.FirstName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" onclick="closeModal('editCourseModal')">Cancel</button>
                <button class="btn btn-primary" onclick="saveEditCourse()">Save Changes</button>
            </div>
        </div>
    </div>

    <!-- Hidden Forms -->
    <form method="post" asp-action="EditCourse" asp-controller="AdminDashboard" id="editCourseForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="ecId" />
        <input type="hidden" name="courseCode" id="ecCodeHidden" />
        <input type="hidden" name="courseName" id="ecNameHidden" />
        <input type="hidden" name="units" id="ecUnitsHidden" />
        <input type="hidden" name="section" id="ecSectionHidden" />
        <input type="hidden" name="schedule" id="ecScheduleHidden" />
        <input type="hidden" name="teacherId" id="ecTeacherIdHidden" />
    </form>
    <form method="post" asp-action="DeleteCourse" asp-controller="AdminDashboard" id="deleteCourseForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="dcId" />
    </form>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.10.5/sweetalert2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.12.0/toastify.min.js"></script>
    <script src="~/js/dashboard.js"></script>
    <script>
        function confirmDeleteCourseFromBtn(btn) {
            Swal.fire({
                title: 'Delete Course?',
                html: `Delete <strong>${btn.dataset.name}</strong>?<br><small style="color:#ef4444">This cannot be undone.</small>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                background: '#1a1f2e',
                color: '#e2e8f0'
            }).then(result => {
                if (result.isConfirmed) {
                    document.getElementById('dcId').value = btn.dataset.id;
                    document.getElementById('deleteCourseForm').submit();
                }
            });
        }
    </script>
</body>
</html>
