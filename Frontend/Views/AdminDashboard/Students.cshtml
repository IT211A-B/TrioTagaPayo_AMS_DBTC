@{
    Layout = null; ViewData["Title"] = "Students";
    var students = ViewBag.Students as List<Frontend.Controllers.StudentDto> ?? new();
    var username = ViewBag.Username?.ToString() ?? "Administrator";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Students – 3TagaPayu AMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.10.5/sweetalert2.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.12.0/toastify.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>
    <div id="pageLoader">
        <img src="~/assets/dbtc.png" alt="Loading" class="loader-logo">
        <div class="loader-dots"><span></span><span></span><span></span></div>
        <p class="loader-text">Loading...</p>
    </div>

    @await Html.PartialAsync("_AdminSidebar", "Students")
    <div class="main">
        @{
            ViewData["User"] = username; ViewData["Role"] = "Admin";
        }
        @await Html.PartialAsync("_Topbar")
        <div class="page-content">

            @if (TempData["Success"] != null)
            {
                <div style="background:#22c55e20;border:1px solid #22c55e;border-radius:8px;padding:12px 16px;margin-bottom:16px;color:#22c55e;font-size:0.85rem;">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div style="background:#ef444420;border:1px solid #ef4444;border-radius:8px;padding:12px 16px;margin-bottom:16px;color:#ef4444;font-size:0.85rem;">
                    <i class="fas fa-times-circle"></i> @TempData["Error"]
                </div>
            }

            <div class="panel">
                <div class="panel-header">
                    <i class="fas fa-user-graduate panel-icon"></i>
                    <img src="~/assets/student_logo.png" alt="">
                    <h2>Manage Students</h2>
                </div>

                <p style="font-size:0.78rem;font-weight:600;color:var(--accent);margin-bottom:12px;letter-spacing:0.5px;">+ ADD NEW STUDENT</p>

                <form method="post" asp-action="AddStudent" asp-controller="AdminDashboard">
                    @Html.AntiForgeryToken()
                    <div class="form-row" style="margin-bottom:20px;flex-wrap:wrap;gap:10px;">
                        <div class="form-field">
                            <label>Student No.</label>
                            <input type="text" name="studentNo" placeholder="2026-XXXX" style="min-width:120px;">
                        </div>
                        <div class="form-field">
                            <label>First Name</label>
                            <input type="text" name="firstName" placeholder="First name" style="min-width:130px;">
                        </div>
                        <div class="form-field">
                            <label>Middle Name</label>
                            <input type="text" name="middleName" placeholder="Optional" style="min-width:110px;">
                        </div>
                        <div class="form-field" style="flex:1">
                            <label>Last Name</label>
                            <input type="text" name="lastName" placeholder="Last name">
                        </div>
                        <div class="form-field" style="flex:1">
                            <label>Email</label>
                            <input type="email" name="email" placeholder="student@dbtc.edu.ph">
                        </div>
                        <div class="form-field">
                            <label>Mobile</label>
                            <input type="text" name="mobileNo" placeholder="+63 9XX">
                        </div>
                        <div class="form-field">
                            <label>Section</label>
                            <select name="section" style="min-width:100px;">
                                <option>IT-3A</option>
                                <option>IT-3B</option>
                                <option>IT-4A</option>
                            </select>
                        </div>
                        <div class="form-field" style="justify-content:flex-end;">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary">Add</button>
                        </div>
                    </div>
                </form>

                <table class="data-table" id="studentsTable" data-dt>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student No.</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Section</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int sn = 1;
                        }
                        @foreach (var s in students)
                        {
                            <tr>
                                <td>@sn</td>
                                <td class="mono">@s.StudentNo</td>
                                <td><strong>@s.LastName, @s.FirstName @s.MiddleName</strong></td>
                                <td style="color:var(--muted)">@s.Email</td>
                                <td><span class="section-tag">@s.Section</span></td>
                                <td>
                                    <div style="display:flex;gap:6px;">
                                        <button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;"
                                                data-id="@s.Id" data-no="@s.StudentNo"
                                                data-first="@s.FirstName" data-mid="@s.MiddleName"
                                                data-last="@s.LastName" data-email="@s.Email"
                                                data-section="@s.Section" data-mobile="@s.MobileNo"
                                                onclick="openEditStudentFromBtn(this)">
                                            Edit
                                        </button>
                                        <button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;"
                                                data-id="@s.Id" data-name="@s.LastName, @s.FirstName"
                                                onclick="confirmDeleteStudentFromBtn(this)">
                                            Del
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            sn++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Edit Student Modal -->
    <div class="modal-backdrop" id="editStudentModal">
        <div class="modal">
            <div class="modal-header">
                <h3><i class="fas fa-user-edit"></i> Edit Student</h3>
                <button class="modal-close" onclick="closeModal('editStudentModal')"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="modal-field"><label>Student No.</label><input type="text" id="editStudentNo" readonly></div>
                <div class="modal-field"><label>First Name</label><input type="text" id="editStudentFirst"></div>
                <div class="modal-field"><label>Middle Name</label><input type="text" id="editStudentMid"></div>
                <div class="modal-field"><label>Last Name</label><input type="text" id="editStudentLast"></div>
                <div class="modal-field"><label>Email</label><input type="email" id="editStudentEmail"></div>
                <div class="modal-field"><label>Mobile</label><input type="text" id="editStudentMobile"></div>
                <div class="modal-field">
                    <label>Section</label>
                    <select id="editStudentSec"><option>IT-3A</option><option>IT-3B</option><option>IT-4A</option></select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" onclick="closeModal('editStudentModal')">Cancel</button>
                <button class="btn btn-primary" onclick="saveEditStudent()">Save Changes</button>
            </div>
        </div>
    </div>

    <!-- ✅ Delete Student Modal (was MISSING — JS broke silently without this) -->
    <div class="modal-backdrop" id="deleteStudentModal">
        <div class="modal">
            <div class="modal-header">
                <h3><i class="fas fa-trash"></i> Delete Student</h3>
                <button class="modal-close" onclick="closeModal('deleteStudentModal')"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteStudentName"></strong>?</p>
                <p style="font-size:0.82rem;color:#ef4444;margin-top:8px;">
                    <i class="fas fa-exclamation-triangle"></i> This will also remove all their attendance records. This cannot be undone.
                </p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" onclick="closeModal('deleteStudentModal')">Cancel</button>
                <button class="btn btn-danger" onclick="submitDeleteStudent()">Yes, Delete</button>
            </div>
        </div>
    </div>

    <!-- Hidden Forms -->
    <form method="post" asp-action="EditStudent" asp-controller="AdminDashboard" id="editStudentForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="esId" />
        <input type="hidden" name="studentNo" id="esNo" />
        <input type="hidden" name="firstName" id="esFirst" />
        <input type="hidden" name="middleName" id="esMid" />
        <input type="hidden" name="lastName" id="esLast" />
        <input type="hidden" name="email" id="esEmail" />
        <input type="hidden" name="section" id="esSection" />
        <input type="hidden" name="mobileNo" id="esMobile" />
    </form>
    <form method="post" asp-action="DeleteStudent" asp-controller="AdminDashboard" id="deleteStudentForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="dsId" />
    </form>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.10.5/sweetalert2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.12.0/toastify.min.js"></script>
    <script src="~/js/dashboard.js"></script>
</body>
</html>
