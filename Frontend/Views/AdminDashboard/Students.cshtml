@{
    Layout = null; ViewData["Title"] = "Students";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Students – 3TagaPayu AMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>
    <!-- Loading screen — change img src to swap logo -->
    <!-- Dots: codepen.io/nzbin/pen/GGrXbp (MIT) | Pulse: uiverse.io loading styles -->
    <div id="pageLoader">
        <img src="~/assets/dbtc.png" alt="Loading" class="loader-logo">
        <div class="loader-dots"><span></span><span></span><span></span></div>
        <p class="loader-text">Loading...</p>
    </div>

    @await Html.PartialAsync("_AdminSidebar", "Students")
    <div class="main">
        @await Html.PartialAsync("_Topbar", new ViewDataDictionary(ViewData) { { "User", "Administrator" }, { "Role", "Admin" } })
        <div class="page-content">
            <div class="panel">
                <div class="panel-header">
                    <i class="fas fa-user-graduate panel-icon"></i>
                    <img src="~/assets/student_logo.png" alt="">
                    <h2>Manage Students</h2>
                </div>

                <p style="font-size:0.78rem;font-weight:600;color:var(--accent);margin-bottom:12px;letter-spacing:0.5px;">+ ADD NEW STUDENT</p>

                <div class="form-row" style="margin-bottom:20px;">
                    <div class="form-field">
                        <label>Student No.</label>
                        <input type="text" value="2026-0009" style="min-width:120px;">
                    </div>
                    <div class="form-field">
                        <label>First Name</label>
                        <input type="text" placeholder="First name" style="min-width:140px;">
                    </div>
                    <div class="form-field">
                        <label>Middle Name</label>
                        <input type="text" placeholder="Optional" style="min-width:120px;">
                    </div>
                    <div class="form-field" style="flex:1">
                        <label>Last Name</label>
                        <input type="text" placeholder="Last name">
                    </div>
                    <div class="form-field">
                        <label>Year &amp; Section</label>
                        <select style="min-width:100px;"><option>IT-3A</option><option>IT-3B</option><option>IT-4A</option></select>
                    </div>
                    <div class="form-field" style="justify-content:flex-end;">
                        <label>&nbsp;</label>
                        <button class="btn btn-primary">Add</button>
                    </div>
                </div>

                <div style="display:flex;gap:12px;align-items:center;margin-bottom:16px;">
                    <div class="search-bar" style="flex:1;margin-bottom:0;">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Search students...">
                    </div>
                    <select style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.85rem;outline:none;">
                        <option>All Sections</option>
                        <option>IT-3A</option>
                        <option>IT-3B</option>
                        <option>IT-4A</option>
                    </select>
                </div>

                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student No.</th>
                            <th>Full Name</th>
                            <th>Section</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="num-col">1</td>
                            <td class="mono">2026-0001</td>
                            <td><strong>Artajo, Armanes Christopher G.</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td><div style="display:flex;gap:6px;"><button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;">Edit</button><button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;">Del</button></div></td>
                        </tr>
                        <tr>
                            <td class="num-col">2</td>
                            <td class="mono">2026-0002</td>
                            <td><strong>Maano, James Neil</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td><div style="display:flex;gap:6px;"><button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;">Edit</button><button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;">Del</button></div></td>
                        </tr>
                        <tr>
                            <td class="num-col">3</td>
                            <td class="mono">2026-0003</td>
                            <td><strong>Moreno, Rimark Rafel</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td><div style="display:flex;gap:6px;"><button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;">Edit</button><button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;">Del</button></div></td>
                        </tr>
                        <tr>
                            <td class="num-col">4</td>
                            <td class="mono">2026-0004</td>
                            <td><strong>Moreno, Anthony Josh</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td><div style="display:flex;gap:6px;"><button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;">Edit</button><button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;">Del</button></div></td>
                        </tr>
                        <tr>
                            <td class="num-col">5</td>
                            <td class="mono">2026-0005</td>
                            <td><strong>Rebese, Vincent</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td><div style="display:flex;gap:6px;"><button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;">Edit</button><button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;">Del</button></div></td>
                        </tr>
                        <tr>
                            <td class="num-col">6</td>
                            <td class="mono">2026-0006</td>
                            <td><strong>Villacorte, John Kevin</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td><div style="display:flex;gap:6px;"><button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;">Edit</button><button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;">Del</button></div></td>
                        </tr>
                        <tr>
                            <td class="num-col">7</td>
                            <td class="mono">2026-0007</td>
                            <td><strong>NobetNov, KenWil</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td><div style="display:flex;gap:6px;"><button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;">Edit</button><button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;">Del</button></div></td>
                        </tr>
                        <tr>
                            <td class="num-col">8</td>
                            <td class="mono">2026-0008</td>
                            <td><strong>Lopez, Francis M.</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td><div style="display:flex;gap:6px;"><button class="btn btn-ghost" style="padding:5px 10px;font-size:0.78rem;">Edit</button><button class="btn btn-danger" style="padding:5px 10px;font-size:0.78rem;">Del</button></div></td>
                        </tr>
                    </tbody>
                </table>

                <div class="pagination">
                    <button class="page-btn active">1</button>
                    <button class="page-btn">2</button>
                    <button class="page-btn">3</button>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/dashboard.js"></script>
</body>
<!-- Edit Student Modal -->
<div class="modal-backdrop" id="editStudentModal">
    <div class="modal">
        <div class="modal-header">
            <h3><i class="fas fa-user-edit"></i> Edit Student</h3>
            <button class="modal-close" onclick="closeModal('editStudentModal')">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body">
            <div class="modal-field">
                <label>Student No.</label>
                <input type="text" id="editStudentNo" readonly>
            </div>
            <div class="modal-field">
                <label>Full Name</label>
                <input type="text" id="editStudentName">
            </div>
            <div class="modal-field">
                <label>Section</label>
                <select id="editStudentSec">
                    <option>IT-3A</option>
                    <option>IT-3B</option>
                    <option>IT-4A</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeModal('editStudentModal')">Cancel</button>
            <button class="btn btn-primary" onclick="saveEditStudent()">Save Changes</button>
        </div>
    </div>
</div>

<!-- Delete Student Modal -->
<div class="modal-backdrop" id="deleteStudentModal">
    <div class="modal">
        <div class="modal-header">
            <h3><i class="fas fa-trash danger"></i> Delete Student</h3>
            <button class="modal-close" onclick="closeModal('deleteStudentModal')">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to delete <strong id="deleteStudentName"></strong>? This action cannot be undone.</p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeModal('deleteStudentModal')">Cancel</button>
            <button class="btn btn-danger" onclick="confirmDeleteStudent()">Yes, Delete</button>
        </div>
    </div>
</div>
</html>