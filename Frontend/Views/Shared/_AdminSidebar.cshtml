@model string
@{
    var username = ViewContext.ViewData["Username"]?.ToString() ?? "Administrator";
    var initials = username.Length >= 2 ? username.Substring(0, 2).ToUpper() : "AD";
}
<div class="sidebar">
    <div class="sidebar-brand">
        <img src="~/assets/dbtc.png" alt="Logo">
        <div class="brand-text">
            <div class="name">3TagaPayu</div>
            <div class="sub">Attendance System</div>
        </div>
    </div>

    <div class="nav-section-label">Main Menu</div>
    <nav class="sidebar-nav">
        <a href="/AdminDashboard/Attendance" class="nav-item @(Model == "Attendance" ? "active" : "")">
            <i class="fas fa-clipboard-check"></i><span>Attendance</span>
        </a>
        <a href="/AdminDashboard/Courses" class="nav-item @(Model == "Courses" ? "active" : "")">
            <i class="fas fa-book"></i><span>Courses</span>
        </a>
        <a href="/AdminDashboard/Students" class="nav-item @(Model == "Students" ? "active" : "")">
            <i class="fas fa-user-graduate"></i><span>Students</span>
        </a>
        <a href="/AdminDashboard/Teachers" class="nav-item @(Model == "Teachers" ? "active" : "")">
            <i class="fas fa-chalkboard-teacher"></i><span>Teachers</span>
        </a>
    </nav>

    <div class="sidebar-user">
        <div class="user-avatar">@initials</div>
        <div class="user-info">
            <div class="uname">@username</div>
            <a href="/Login/Logout" class="logout-link">Logout</a>
        </div>
    </div>
</div>
