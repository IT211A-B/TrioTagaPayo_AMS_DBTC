@{
    Layout = null; ViewData["Title"] = "Att. Records";
    var courses = ViewBag.Courses as List<Frontend.Controllers.CourseDto> ?? new();
    var username = ViewBag.Username?.ToString() ?? "Teacher";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Att. Records – 3TagaPayu AMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>
    <div id="pageLoader">
        <img src="~/assets/dbtc.png" alt="Loading" class="loader-logo">
        <div class="loader-dots"><span></span><span></span><span></span></div>
        <p class="loader-text">Loading...</p>
    </div>

    @await Html.PartialAsync("_TeacherSidebar", "Records")
    <div class="main">
        @{
            ViewData["User"] = username; ViewData["Role"] = "Teacher";
        }
        @await Html.PartialAsync("_Topbar")
        <div class="page-content">
            <div class="panel">
                <div class="panel-header">
                    <i class="fas fa-chart-bar panel-icon"></i>
                    <img src="~/assets/Teacher_logo.png" alt="">
                    <h2>Attendance Records</h2>
                </div>

                <div class="form-row" style="margin-bottom:20px;">
                    <div class="form-field" style="flex:1">
                        <label>Course</label>
                        <select id="recordCourseSelect">
                            @foreach (var c in courses)
                            {
                                <option value="@c.Id">@c.CourseCode – @c.CourseName</option>
                            }
                        </select>
                    </div>
                    <div class="form-field">
                        <label>From Date</label>
                        <input type="date" id="fromDate" value="@DateTime.Today.AddDays(-14).ToString("yyyy-MM-dd")">
                    </div>
                    <div class="form-field">
                        <label>To Date</label>
                        <input type="date" id="toDate" value="@DateTime.Today.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="form-field" style="justify-content:flex-end;">
                        <label>&nbsp;</label>
                        <button class="btn btn-primary" onclick="filterRecords()">Filter</button>
                    </div>
                </div>

                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Student No.</th>
                            <th>Name</th>
                            <th>Status</th>
                            <th>Remarks</th>
                        </tr>
                    </thead>
                    <tbody id="recordsBody">
                        <tr>
                            <td colspan="5" style="text-align:center;color:var(--muted);padding:24px;">
                                Select a course and date range, then click Filter.
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:18px;">
                    <button class="btn btn-ghost" onclick="exportCSV()">Export CSV</button>
                    <button class="btn btn-success" onclick="window.print()">Print Report</button>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/dashboard.js"></script>
</body>
</html>
