@{
    Layout = null;
    ViewData["Title"] = "My Students";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>My Students - 3TagaPayu AMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>
    <div id="pageLoader">
        <img src="~/assets/dbtc.png" alt="Loading" class="loader-logo">
        <div class="loader-dots">
            <span></span>
            <span></span>
            <span></span>
        </div>
        <p class="loader-text">Loading...</p>
    </div>

    @await Html.PartialAsync("_TeacherSidebar", "Students")

    <div class="main">
        @await Html.PartialAsync("_Topbar", new ViewDataDictionary(ViewData) { { "User", "Carl Joshua Santos" }, { "Role", "Teacher" } })
        <div class="page-content">
            <div class="panel">
                <div class="panel-header">
                    <i class="fas fa-user-graduate panel-icon"></i>
                    <img src="~/assets/student_logo.png" alt="">
                    <h2>My Students</h2>
                </div>

                <div style="display:flex;gap:12px;align-items:center;margin-bottom:16px;">
                    <div class="search-bar" style="flex:1;margin-bottom:0;">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Search students...">
                    </div>
                    <select style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.85rem;outline:none;">
                        <option>IT 212A - Network Management 2</option>
                        <option>IT 214A - Capstone Project 1</option>
                        <option>IT 216A - Database Management</option>
                    </select>
                </div>

                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student No.</th>
                            <th>Name</th>
                            <th>Section</th>
                            <th>Attendance %</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="num-col">1</td>
                            <td class="mono">2026-0001</td>
                            <td><strong>Artajo, Armanes Christopher G.</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td>
                                <div class="att-bar-wrap">
                                    <div class="att-bar">
                                        <div class="att-bar-fill" style="width:95%"></div>
                                    </div>
                                    <span class="att-pct">95%</span>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">2</td>
                            <td class="mono">2026-0002</td>
                            <td><strong>Maano, James Neil</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td>
                                <div class="att-bar-wrap">
                                    <div class="att-bar">
                                        <div class="att-bar-fill warn" style="width:72%"></div>
                                    </div>
                                    <span class="att-pct warn">72%</span>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">3</td>
                            <td class="mono">2026-0003</td>
                            <td><strong>Moreno, Rimark Rafel</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td>
                                <div class="att-bar-wrap">
                                    <div class="att-bar">
                                        <div class="att-bar-fill" style="width:88%"></div>
                                    </div>
                                    <span class="att-pct">88%</span>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">4</td>
                            <td class="mono">2026-0004</td>
                            <td><strong>Moreno, Anthony Josh</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td>
                                <div class="att-bar-wrap">
                                    <div class="att-bar">
                                        <div class="att-bar-fill" style="width:100%"></div>
                                    </div>
                                    <span class="att-pct">100%</span>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">5</td>
                            <td class="mono">2026-0005</td>
                            <td><strong>Rebese, Vincent</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td>
                                <div class="att-bar-wrap">
                                    <div class="att-bar">
                                        <div class="att-bar-fill" style="width:91%"></div>
                                    </div>
                                    <span class="att-pct">91%</span>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">6</td>
                            <td class="mono">2026-0006</td>
                            <td><strong>Villacorte, John Kevin</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td>
                                <div class="att-bar-wrap">
                                    <div class="att-bar">
                                        <div class="att-bar-fill warn" style="width:78%"></div>
                                    </div>
                                    <span class="att-pct warn">78%</span>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">7</td>
                            <td class="mono">2026-0007</td>
                            <td><strong>NobetNov, KenWil</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td>
                                <div class="att-bar-wrap">
                                    <div class="att-bar">
                                        <div class="att-bar-fill" style="width:85%"></div>
                                    </div>
                                    <span class="att-pct">85%</span>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="num-col">8</td>
                            <td class="mono">2026-0008</td>
                            <td><strong>Lopez, Francis M.</strong></td>
                            <td><span class="section-tag">IT-3A</span></td>
                            <td>
                                <div class="att-bar-wrap">
                                    <div class="att-bar">
                                        <div class="att-bar-fill" style="width:96%"></div>
                                    </div>
                                    <span class="att-pct">96%</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="pagination">
                    <button class="page-btn active">1</button>
                    <button class="page-btn">2</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/dashboard.js"></script>
</body>
</html>