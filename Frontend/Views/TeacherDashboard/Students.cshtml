@{
    Layout = null; ViewData["Title"] = "My Students";
    var students = ViewBag.Students as List<Frontend.Controllers.StudentDto> ?? new();
    var courses = ViewBag.Courses as List<Frontend.Controllers.CourseDto> ?? new();
    var username = ViewBag.Username?.ToString() ?? "Teacher";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>My Students – 3TagaPayu AMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>
    <div id="pageLoader">
        <img src="~/assets/dbtc.png" alt="Loading" class="loader-logo">
        <div class="loader-dots"><span></span><span></span><span></span></div>
        <p class="loader-text">Loading...</p>
    </div>

    @await Html.PartialAsync("_TeacherSidebar", "Students")
    <div class="main">
        @{
            ViewData["User"] = username; ViewData["Role"] = "Teacher";
        }
        @await Html.PartialAsync("_Topbar")
        <div class="page-content">
            <div class="panel">
                <div class="panel-header">
                    <i class="fas fa-user-graduate panel-icon"></i>
                    <img src="~/assets/student_logo.png" alt="">
                    <h2>My Students</h2>
                </div>

                <div style="display:flex;gap:12px;align-items:center;margin-bottom:16px;">
                    <div class="search-bar" style="flex:1;margin-bottom:0;">
                        <i class="fas fa-search"></i>
                        <input type="text" id="studentSearch" placeholder="Search students..." oninput="filterStudents()">
                    </div>
                    <select id="sectionFilter" onchange="filterStudents()"
                            style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.85rem;outline:none;">
                        <option value="">All Courses</option>
                        @foreach (var c in courses)
                        {
                            <option value="@c.Section">@c.CourseCode – @c.CourseName</option>
                        }
                    </select>
                </div>

                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student No.</th>
                            <th>Name</th>
                            <th>Section</th>
                            <th>Email</th>
                        </tr>
                    </thead>
                    <tbody id="studentBody">
                        @{
                            int sn = 1;
                        }
                        @foreach (var s in students)
                        {
                            <tr data-name="@($"{s.LastName} {s.FirstName}").ToLower()" data-section="@s.Section">
                                <td class="num-col">@sn</td>
                                <td class="mono">@s.StudentNo</td>
                                <td><strong>@s.LastName, @s.FirstName @s.MiddleName</strong></td>
                                <td><span class="section-tag">@s.Section</span></td>
                                <td style="color:var(--muted)">@s.Email</td>
                            </tr>
                            sn++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script src="~/js/dashboard.js"></script>
</body>
</html>
