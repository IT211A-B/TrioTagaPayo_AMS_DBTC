@model Frontend.Models.LoginViewModel
@{
    ViewData["Title"] = "Login - 3TagaPayu AMS";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3TagaPayu AMS - Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/login.css">
</head>
<body>
    <div class="background-image"></div>
    <div class="bg-overlay"></div>

    <div class="login-container">

        <div class="header">
            <img src="~/assets/dbtc.png" alt="DBTC Logo" class="logo">
            <div class="header-text">
                <h1>Don Bosco Technical College</h1>
                <p>Cebu City</p>
            </div>
        </div>

        <div class="card-wrapper">
            <div class="login-card">
                <div class="card-header">
                    <img src="~/assets/dbtc.png" alt="3TagaPayu AMS" class="card-logo">
                    <h2>3TagaPayu AMS</h2>
                    <p class="subtitle">Attendance Management System</p>
                </div>

                <div class="user-type-selector">
                    <button type="button" class="user-type-btn admin-btn active">
                        <img src="~/assets/student_logo.png" alt="Admin">
                        Admin
                    </button>
                    <button type="button" class="user-type-btn teacher-btn">
                        <img src="~/assets/Teacher_logo.png" alt="Teacher">
                        Teacher
                    </button>
                </div>

                <form method="post" asp-action="Login" asp-controller="Login">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="userType" name="UserType" value="Admin">

                    <div class="form-group">
                        <label class="form-label">Username</label>
                        <input id="Username" name="Username" type="text"
                               class="form-input" placeholder="Enter admin username" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <input name="Password" type="password"
                               class="form-input" placeholder="Enter password" />
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <p class="error-msg">Invalid username or password.</p>
                    }

                    <button type="submit" class="sign-in-btn">Sign In as Admin →</button>
                    <p class="footer-text">Administrator access only</p>
                </form>
            </div>
        </div>

        <div class="quote">
            <p>"The Lord is my shepherd, I shall not fear."</p>
            <p class="quote-source">— Psalm 23:1</p>
        </div>

    </div>

    <script src="~/js/login.js"></script>
</body>
</html>